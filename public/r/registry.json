{
	"$schema": "https://ui.shadcn.com/schema/registry.json",
	"name": "audx",
	"homepage": "https://audx.site",
	"items": [
		{
			"name": "audio-types",
			"type": "registry:lib",
			"title": "Audio Types",
			"description": "TypeScript type definitions for audx audio assets.",
			"files": [
				{
					"path": "registry/audx/lib/audio-types.ts",
					"type": "registry:lib"
				}
			],
			"categories": ["lib"]
		},
		{
			"name": "use-audio",
			"type": "registry:hook",
			"title": "useAudio",
			"description": "A lightweight React hook for playing UI audio effects using the Web Audio API. Zero dependencies.",

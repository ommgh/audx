generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String           @id
  name            String
  email           String
  emailVerified   Boolean          @default(false)
  image           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @default(now()) @updatedAt
  dodoCustomerId  String?
  sessions        Session[]
  accounts        Account[]
  generatedThemes GeneratedTheme[]
  generatedSounds GeneratedSound[]
  payments        Payment[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

model GeneratedTheme {
  id           String   @id @default(cuid())
  name         String
  prompt       String
  blobIndexUrl String
  assetCount   Int
  createdAt    DateTime @default(now())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@map("generated_theme")
}

model GeneratedSound {
  id        String   @id @default(cuid())
  prompt    String
  blobUrl   String
  duration  Float
  sizeKb    Int
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("generated_sound")
}

model Payment {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentId   String   @unique
  productId   String?
  status      String
  amount      Int
  currency    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("payment")
}

model Patch {
  id            Int          @id @default(autoincrement())
  name          String       @unique
  author        String
  description   String
  soundCount    Int          @default(0) @map("sound_count")
  url           String
  source        String?
  sourceUrl     String?      @map("source_url")
  patchJson     Json?        @map("patch_json")
  createdAt     DateTime     @default(now()) @map("created_at")
  version       String?
  updatedAt     DateTime     @default(now()) @updatedAt @map("updated_at")
  license       String?
  compatibility String?
  featured      Boolean      @default(false)
  verified      Boolean      @default(false)
  forkedFrom    Int?         @map("forked_from")
  sourceTypes   String[]     @default([]) @map("source_types")
  hasEffects    Boolean      @default(false) @map("has_effects")
  hasLayers     Boolean      @default(false) @map("has_layers")
  fileSize      Int          @default(0) @map("file_size")

  // Relations
  loads         PatchLoad[]
  sounds        PatchSound[]
  forkedFromPatch Patch?     @relation("PatchForks", fields: [forkedFrom], references: [id])
  forks         Patch[]      @relation("PatchForks")

  @@map("patches")
}

model PatchLoad {
  id       Int      @id @default(autoincrement())
  patchId  Int      @map("patch_id")
  loadedAt DateTime @default(now()) @map("loaded_at")

  // Relations
  patch    Patch    @relation(fields: [patchId], references: [id], onDelete: Cascade)

  @@index([loadedAt])
  @@index([patchId])
  @@map("patch_loads")
}

model PatchSound {
  id          Int     @id @default(autoincrement())
  patchId     Int     @map("patch_id")
  name        String
  category    String
  description String?

  // Relations
  patch       Patch   @relation(fields: [patchId], references: [id], onDelete: Cascade)

  @@unique([patchId, name])
  @@map("patch_sounds")
}
